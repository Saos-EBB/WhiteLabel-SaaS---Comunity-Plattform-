# PostgreSQL
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# pgAdmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_pgadmin_password

# JWT
JWT_SECRET=your-long-random-jwt-secret
EMAIL_SALT=your-random-salt-here

# Resend
RESEND_API_KEY=re_your_resend_api_key

# App
APP_URL=http://localhost:3001
CORS_ORIGIN=https://your-domain.com

# AES-256 encryption key (32 bytes = 64 hex chars)
APP_ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:3001/payment/success
STRIPE_CANCEL_URL=http://localhost:3001/payment/cancel
